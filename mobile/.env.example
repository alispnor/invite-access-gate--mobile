# ═══════════════════════════════════════════════════════════════
# GUÉP Portaria Mobile — Variáveis de ambiente
# ═══════════════════════════════════════════════════════════════
#
# Trocar ambiente:
#   npm run start:dev      → Desenvolvimento
#   npm run start:hom      → Homologação
#   npm run start:prod     → Produção
#   npm run start:local    → Backend local (localhost:3000)
#
# Ou manual:  cp .env.dev .env && npx expo start
# ═══════════════════════════════════════════════════════════════

# Ambiente: local | dev | hom | prod
# Puxa automaticamente API URL + Keycloak de src/config/presets.ts
# (espelho 1:1 de frontend/app/src/environments/environment*.ts)
EXPO_PUBLIC_APP_ENV=dev

# Mesmo clientId do Angular — já existe no Keycloak
# local → localhost-frontend | dev/hom/prod → portaria-frontend
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=portaria-frontend

# Sobrescritas opcionais:
# EXPO_PUBLIC_API_BASE_URL=
# EXPO_PUBLIC_KEYCLOAK_URL=
# EXPO_PUBLIC_KEYCLOAK_REALM=
# EXPO_PUBLIC_PRODUCTION=true
# EXPO_PUBLIC_LOCAL=true
# EXPO_PUBLIC_TENANT_ID=
